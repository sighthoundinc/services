{
    "one-person-one-car" : {
        "pipeline"      : "./share/pipelines/TrafficAnalytics/TrafficAnalyticsRTSP.yaml",
        "restartPolicy" : "restart",
        "parameters" : {
            "VIDEO_IN" : "rtsp://live555/one-person-one-car.mkv",
            "fpsLimit" : "1",
            "sourceId" : "one-person-one-car",
            "recordTo":"/tmp/mcp/output/video/one-person-one-car/",
            "imageSaveDir":"/tmp/mcp/output/image/one-person-one-car/",
            "amqpHost":"rabbitmq",
            "amqpPort":"5672",
            "amqpExchange":"amq.topic",
            "amqpUser":"guest",
            "amqpPassword":"guest",
            "amqpErrorOnFailure":"true"
        }
    }
}